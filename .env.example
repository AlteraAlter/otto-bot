# OTTO API
OTTO_JV_CLIENT_ID=your_client_id
OTTO_JV_CLIENT_SECRET=your_client_secret
OTTO_BASE_URL=https://api.otto.market
OTTO_SCOPE=orders products
OTTO_TIMEOUT_SECONDS=20.0

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=otto
DB_USER=postgres
DB_PASS=your_db_password

# Auth
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1200
FRONTEND_APP_URL=http://127.0.0.1:3000
EMPLOYEE_INVITATION_EXPIRE_HOURS=48

# Invitation email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_username
SMTP_PASSWORD=your_app_password
SMTP_SENDER_EMAIL=your_gmail_address@gmail.com
SMTP_USE_TLS=true

# Frontend server-side proxy to backend
BACKEND_BASE_URL=http://127.0.0.1:8000

# Optional category mapper override
# OTTO_CATEGORIES_FILE=/absolute/path/to/available_cats.json
