# Service settings
PORT=3000

# Incoming request auth (protects your service)
SERVICE_BEARER_TOKEN=replace_with_service_token
ALLOWED_CLIENT_ID=replace_with_client_id
ALLOWED_CLIENT_KEY=replace_with_client_key

# Otto API settings (used when calling Otto)
OTTO_BASE_URL=https://api.otto.example.com
OTTO_API_TOKEN=replace_with_otto_api_token
OTTO_CLIENT_ID=replace_with_otto_client_id
OTTO_CLIENT_KEY=replace_with_otto_client_key
